# ============================================================
# CAELab Environment Variables Template
# Copy this file to .env and fill in the values
# ============================================================

# ---- Stripe Payment ----
# Stripe Publishable Key (client-side)
VITE_STRIPE_PUBLISHABLE_KEY=
# Stripe Secret Key (server-side, Rust backend)
STRIPE_SECRET_KEY=
# Stripe Webhook Secret (for verifying webhook signatures)
STRIPE_WEBHOOK_SECRET=

# ---- OAuth: Google ----
# Google OAuth 2.0 Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=
# Google OAuth 2.0 Client Secret (server-side)
GOOGLE_CLIENT_SECRET=

# ---- OAuth: GitHub ----
# GitHub OAuth App Client ID (from GitHub Developer Settings)
VITE_GITHUB_CLIENT_ID=
# GitHub OAuth App Client Secret (server-side)
GITHUB_CLIENT_SECRET=
